# =============================================================================
# Adaptive Language Study Bot — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# Required variables are marked with (required).

# --- Telegram ---
TELEGRAM_BOT_TOKEN=           # (required) Bot token from @BotFather

# --- Anthropic ---
ANTHROPIC_API_KEY=            # (required) API key from console.anthropic.com

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=langbot
POSTGRES_PASSWORD=            # (required) Database password
POSTGRES_DB=langbot

# PostgreSQL connection pool
DB_POOL_SIZE=30
DB_MAX_OVERFLOW=40
DB_POOL_RECYCLE=3600          # seconds

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50

# --- Session Manager ---
MAX_CONCURRENT_INTERACTIVE_SESSIONS=50
MAX_CONCURRENT_PROACTIVE_SESSIONS=10

# --- Proactive Engine ---
PROACTIVE_TICK_INTERVAL_SECONDS=60

# --- Admin Panel ---
ADMIN_HOST=0.0.0.0
ADMIN_PORT=7860
ADMIN_API_TOKEN=              # Set to require Gradio login (empty = no auth)
ADMIN_TELEGRAM_IDS=[]         # JSON array of admin Telegram IDs, e.g. [123456789]

# --- Web Search (Tavily) --- optional, search tool disabled when empty
TAVILY_API_KEY=              # Free tier at tavily.com (1000 credits/month)

# --- Logging ---
LOG_LEVEL=INFO                # Log level: INFO or DEBUG (default: INFO), togglable at runtime via /settings

# --- Metrics ---
METRICS_PORT=9090             # Prometheus metrics HTTP server port
